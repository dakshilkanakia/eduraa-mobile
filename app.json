{
  "expo": {
    "name": "Eduraa",
    "slug": "eduraa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eduraa.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f8fafc"
      },
      "package": "com.eduraa.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Eduraa to access your camera for scanning answer sheets."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Eduraa to access your photos for uploading answer sheets."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "7bafb9d9-c7f0-4d9b-a126-8b2645ad4cd3"
      }
    }
  }
}
